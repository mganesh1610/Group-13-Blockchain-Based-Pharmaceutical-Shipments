PORT=4000
CORS_ORIGIN=http://localhost:5173
# Optional. Defaults to backend/src/uploads.
UPLOAD_DIR=

# Optional Azure SQL persistence. If all four required values are set, the API
# stores IoT logs and metadata in Azure SQL instead of local files.
AZURE_SQL_SERVER=biodosymetry.database.windows.net
AZURE_SQL_DATABASE=free-sql-db-3813313
AZURE_SQL_USER=
AZURE_SQL_PASSWORD=
AZURE_SQL_PORT=1433
AZURE_SQL_ENCRYPT=true
AZURE_SQL_TRUST_SERVER_CERTIFICATE=false
AZURE_SQL_RETRY_ATTEMPTS=5
AZURE_SQL_RETRY_BASE_DELAY_MS=5000

# Optional Azure Blob Storage for raw IoT JSON/CSV files. If configured, raw
# files are stored in Blob Storage while Azure SQL stores metadata and hashes.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=iot-logs
